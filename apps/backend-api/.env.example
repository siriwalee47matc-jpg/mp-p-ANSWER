# ============================================================
# Backend API – Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# Server
PORT=3001

# JWT Secret (required in production; use at least 32 random characters)
JWT_SECRET=replace-with-a-long-random-secret

# Database (PostgreSQL is required for persistent production data)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sentinel_ads?sslmode=require"

# Comma-separated dashboard origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

# Initial administrator is created once when all values are present.
# Remove INITIAL_ADMIN_PASSWORD after the first successful production startup.
INITIAL_ADMIN_EMAIL=admin@your-agency.go.th
INITIAL_ADMIN_NAME=System Administrator
INITIAL_ADMIN_PASSWORD=replace-with-a-unique-long-password

# ============================================================
# AI API Configuration
# Uncomment and set the provider you want to use
# ============================================================

# --- Google Gemini (recommended) ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=replace-with-your-key
# GEMINI_MODEL=gemini-3.5-flash

# --- OpenAI (alternative) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude (alternative) ---
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ============================================================
# Email / SMTP Configuration (for risk alerts)
# ============================================================

# --- Resend (recommended for production) ---
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=replace-with-your-key
# EMAIL_FROM=no-reply@sentinelads.com
# EMAIL_TO=inspector@fda.go.th

# --- Gmail SMTP ---
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=alerts@example.org
# SMTP_PASS=replace-with-an-app-password
# EMAIL_FROM=alerts@example.org
# EMAIL_TO=inspector@fda.go.th

# --- Ethereal (test/dev only – auto-created) ---
EMAIL_PROVIDER=ethereal

# Required in production for real AI analysis. Never expose this key in the Extension.
AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-server-side-api-key
GEMINI_MODEL=gemini-3.5-flash
